# Server
PORT=8080

# etcd
# Local run from host: localhost:2379
# Docker Compose app container: etcd:2379
ETCD_ENDPOINT=localhost:2379

# MongoDB
# Local MongoDB:
# MONGO_URI=mongodb://localhost:27017
# MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017
MONGO_DB=dscasestudy

# Optional host-only delete token for DELETE /delete/:hash
# Leave empty to disable delete endpoint authorization.
HOST_TOKEN=change-me
